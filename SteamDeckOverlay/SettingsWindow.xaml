<Window x:Class="SteamDeckOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay Settings" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Overlay Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Opacity:" VerticalAlignment="Center" Width="100"/>
            <Slider x:Name="SldOpacity" Minimum="0" Maximum="1" Value="0.8" Width="150" ValueChanged="SldOpacity_ValueChanged" LargeChange="0.1" SmallChange="0.05" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
            <TextBlock x:Name="TxtOpacityVal" Text="80%" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <CheckBox x:Name="ChkTopPanel" Grid.Row="2" Content="Show Top Panel (Status Bar)" Margin="0,10" Checked="ChkTopPanel_CheckedChanged" Unchecked="ChkTopPanel_CheckedChanged"/>
        
        <CheckBox x:Name="ChkBottomPanel" Grid.Row="3" Content="Show Bottom Panel (Buttons)" Margin="0,10" Checked="ChkBottomPanel_CheckedChanged" Unchecked="ChkBottomPanel_CheckedChanged"/>

        <Button Grid.Row="4" Content="Reset to Default" Width="120" HorizontalAlignment="Left" Margin="0,20,0,0" Padding="5" Click="BtnReset_Click"/>

    </Grid>
</Window>
